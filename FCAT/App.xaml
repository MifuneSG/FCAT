<Application x:Class="FCAT.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FCAT"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             xmlns:views="clr-namespace:FCAT.Views"
             Startup="OnStartup">
    <Application.Resources>

        <!-- ════════════════════════════════════════════════════════════
             FCAT PALETTE — refined dark "cockpit"
             Restraint over rainbow: near-black surfaces, hairline borders,
             one cool cyan accent, gold reserved for the FC, role shown by
             small accent bars/chips rather than loud text colours.
        ════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="EveWindowBg"       Color="#0b0e14"/>   <!-- window base -->
        <SolidColorBrush x:Key="EvePanelBg"        Color="#ee12171f"/> <!-- 93% surface -->
        <SolidColorBrush x:Key="EveRaisedBg"       Color="#ff1a212b"/> <!-- hover / raised -->
        <SolidColorBrush x:Key="EveRowAltBg"       Color="#5910151e"/> <!-- subtle row tint -->

        <SolidColorBrush x:Key="EveHairline"       Color="#1f2735"/>   <!-- default border -->
        <SolidColorBrush x:Key="EveHairlineSoft"   Color="#161c27"/>
        <SolidColorBrush x:Key="EveHairlineStrong" Color="#2b3545"/>

        <SolidColorBrush x:Key="EveAccent"         Color="#4db8d4"/>   <!-- cyan — live/interactive -->
        <SolidColorBrush x:Key="EveAccentDim"      Color="#2c6c7e"/>

        <SolidColorBrush x:Key="EveGold"           Color="#d4a449"/>   <!-- FC / wing only -->
        <SolidColorBrush x:Key="EveGoldSoft"       Color="#f0d99a"/>
        <SolidColorBrush x:Key="EveGoldDim"        Color="#7a6530"/>

        <SolidColorBrush x:Key="EveCritical"       Color="#e2574c"/>   <!-- alerts -->
        <SolidColorBrush x:Key="EveAmber"          Color="#c9883e"/>
        <SolidColorBrush x:Key="EveGreen"          Color="#3fae8f"/>

        <SolidColorBrush x:Key="EveTextPrimary"    Color="#e6ebf2"/>
        <SolidColorBrush x:Key="EveTextSecondary"  Color="#9aa3b3"/>
        <SolidColorBrush x:Key="EveTextDim"        Color="#5c6473"/>

        <!-- Back-compat aliases (older bindings still reference these names) -->
        <SolidColorBrush x:Key="EveDeepBg"         Color="#00000000"/>
        <SolidColorBrush x:Key="EveBorderBrush"    Color="#1f2735"/>
        <SolidColorBrush x:Key="EveGoldBrush"      Color="#d4a449"/>
        <SolidColorBrush x:Key="EveGoldDimBrush"   Color="#7a6530"/>
        <SolidColorBrush x:Key="EveBlueBrush"      Color="#5a8fd6"/>
        <SolidColorBrush x:Key="EveBlueDimBrush"   Color="#34527d"/>
        <SolidColorBrush x:Key="EveRedBrush"       Color="#e2574c"/>
        <SolidColorBrush x:Key="EveGreenBrush"     Color="#3fae8f"/>
        <SolidColorBrush x:Key="EveAmberBrush"     Color="#c9883e"/>
        <SolidColorBrush x:Key="EveTextDimBrush"   Color="#5c6473"/>

        <!-- ══ TYPOGRAPHY TOKENS ══ -->
        <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
        <FontFamily x:Key="FontMono">Cascadia Mono, Consolas</FontFamily>

        <!-- ══ VALUE CONVERTERS ══ -->
        <local:BoolToVisibilityConverter   x:Key="BoolToVisibility"/>
        <local:BoolToInvisibilityConverter x:Key="BoolToInvisibility"/>
        <local:InvertBoolConverter         x:Key="InvertBool"/>
        <local:CountToVisibilityConverter  x:Key="CountToVisibility"/>
        <local:CountToInvisibilityConverter x:Key="CountToInvisibility"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <local:RoleToColorConverter        x:Key="RoleColor"/>
        <local:UrlToImageConverter         x:Key="UrlToImage"/>

        <!-- ════════════════════════════════════════════════════════════
             CARD — flat surface, hairline border, soft rounded corners
        ════════════════════════════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource EvePanelBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource EveHairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
        </Style>

        <!-- ════════════════════════════════════════════════════════════
             BUTTONS — rounded, flat, restrained
        ════════════════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#16202b"/>
            <Setter Property="Foreground"       Value="{StaticResource EveAccent}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource EveAccentDim}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"  Value="#1d2c3a"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource EveAccent}"/>
                                <Setter Property="Foreground" Value="#86d6ea"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource EveTextSecondary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource EveHairlineStrong}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EveRaisedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource EveTextDim}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EveRaisedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ SMALL UPPERCASE SECTION LABEL ══ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <!-- ══ SLIM SCROLLBAR ══ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4" Background="#2b3545" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ PAGE → VIEW MAPPINGS ══ -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MenuViewModel}">
            <views:MenuView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DScanViewModel}">
            <views:DScanView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FleetViewModel}">
            <views:FleetView/>
        </DataTemplate>

    </Application.Resources>
</Application>
