<Application x:Class="FCAT.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FCAT"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             xmlns:views="clr-namespace:FCAT.Views"
             Startup="OnStartup">
    <Application.Resources>

        <!-- ════════════════════════════════════════════════════════════
             FCAT PALETTE — refined dark "cockpit"
             Restraint over rainbow: near-black surfaces, hairline borders,
             one cool cyan accent, gold reserved for the FC, role shown by
             small accent bars/chips rather than loud text colours.
        ════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="EveWindowBg"       Color="#0b0e14"/>   <!-- window base -->
        <SolidColorBrush x:Key="EvePanelBg"        Color="#ee12171f"/> <!-- 93% surface -->
        <SolidColorBrush x:Key="EveRaisedBg"       Color="#ff1a212b"/> <!-- hover / raised -->
        <SolidColorBrush x:Key="EveRowAltBg"       Color="#5910151e"/> <!-- subtle row tint -->

        <SolidColorBrush x:Key="EveHairline"       Color="#1f2735"/>   <!-- default border -->
        <SolidColorBrush x:Key="EveHairlineSoft"   Color="#161c27"/>
        <SolidColorBrush x:Key="EveHairlineStrong" Color="#2b3545"/>

        <SolidColorBrush x:Key="EveAccent"         Color="#4db8d4"/>   <!-- cyan — live/interactive -->
        <SolidColorBrush x:Key="EveAccentDim"      Color="#2c6c7e"/>

        <SolidColorBrush x:Key="EveGold"           Color="#d4a449"/>   <!-- FC / wing only -->
        <SolidColorBrush x:Key="EveGoldSoft"       Color="#f0d99a"/>
        <SolidColorBrush x:Key="EveGoldDim"        Color="#7a6530"/>

        <SolidColorBrush x:Key="EveCritical"       Color="#e2574c"/>   <!-- alerts -->
        <SolidColorBrush x:Key="EveAmber"          Color="#c9883e"/>
        <SolidColorBrush x:Key="EveGreen"          Color="#3fae8f"/>

        <SolidColorBrush x:Key="EveTextPrimary"    Color="#e6ebf2"/>
        <SolidColorBrush x:Key="EveTextSecondary"  Color="#9aa3b3"/>
        <SolidColorBrush x:Key="EveTextDim"        Color="#5c6473"/>

        <!-- Back-compat aliases (older bindings still reference these names) -->
        <SolidColorBrush x:Key="EveDeepBg"         Color="#00000000"/>
        <SolidColorBrush x:Key="EveBorderBrush"    Color="#1f2735"/>
        <SolidColorBrush x:Key="EveGoldBrush"      Color="#d4a449"/>
        <SolidColorBrush x:Key="EveGoldDimBrush"   Color="#7a6530"/>
        <SolidColorBrush x:Key="EveBlueBrush"      Color="#5a8fd6"/>
        <SolidColorBrush x:Key="EveBlueDimBrush"   Color="#34527d"/>
        <SolidColorBrush x:Key="EveRedBrush"       Color="#e2574c"/>
        <SolidColorBrush x:Key="EveGreenBrush"     Color="#3fae8f"/>
        <SolidColorBrush x:Key="EveAmberBrush"     Color="#c9883e"/>
        <SolidColorBrush x:Key="EveTextDimBrush"   Color="#5c6473"/>

        <!-- ══ TYPOGRAPHY TOKENS ══ -->
        <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
        <FontFamily x:Key="FontMono">Cascadia Mono, Consolas</FontFamily>

        <!-- ══ VALUE CONVERTERS ══ -->
        <local:BoolToVisibilityConverter   x:Key="BoolToVisibility"/>
        <local:BoolToInvisibilityConverter x:Key="BoolToInvisibility"/>
        <local:InvertBoolConverter         x:Key="InvertBool"/>
        <local:CountToVisibilityConverter  x:Key="CountToVisibility"/>
        <local:CountToInvisibilityConverter x:Key="CountToInvisibility"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <local:RoleToColorConverter        x:Key="RoleColor"/>
        <local:UrlToImageConverter         x:Key="UrlToImage"/>
        <local:BoolToAccentBrushConverter  x:Key="TabAccent"/>
        <local:NavActiveConverter          x:Key="NavActive"/>
        <local:NavActiveBrushConverter     x:Key="NavActiveBrush"
            ActiveBrush="#4db8d4" InactiveBrush="#5c6473"/>
        <local:NavActiveMultiConverter     x:Key="NavActiveMulti"/>

        <!-- ════════════════════════════════════════════════════════════
             CARD — flat surface, hairline border, soft rounded corners
        ════════════════════════════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource EvePanelBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource EveHairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
        </Style>

        <!-- ════════════════════════════════════════════════════════════
             BUTTONS — rounded, flat, restrained
        ════════════════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#16202b"/>
            <Setter Property="Foreground"       Value="{StaticResource EveAccent}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource EveAccentDim}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"  Value="#1d2c3a"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource EveAccent}"/>
                                <Setter Property="Foreground" Value="#86d6ea"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource EveTextSecondary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource EveHairlineStrong}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EveRaisedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource EveTextDim}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EveRaisedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════════════════════════════════════════════════════════════
             NAV RAIL BUTTON — icon over tiny label, left accent bar + fill
             when active. Active state read via MultiBinding(ActiveNav, Tag).
        ════════════════════════════════════════════════════════════ -->
        <Style x:Key="NavRailButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource EveTextDim}"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="58"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- active left accent bar -->
                            <Rectangle x:Name="bar" Width="3" HorizontalAlignment="Left"
                                       Margin="0,12" RadiusX="2" RadiusY="2"
                                       Fill="{StaticResource EveAccent}" Opacity="0"/>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="9" Margin="7,4"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource EveRaisedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextSecondary}"/>
                            </Trigger>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource NavActiveMulti}">
                                        <Binding Path="DataContext.ActiveNav" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="bar" Property="Opacity" Value="1"/>
                                <Setter TargetName="bg" Property="Background" Value="#14202e"/>
                                <Setter Property="Foreground" Value="{StaticResource EveAccent}"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ FEATURE CARD BUTTON — large clickable card with hover lift ══ -->
        <Style x:Key="FeatureCardButton" TargetType="Button">
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{StaticResource EvePanelBg}"
                                BorderBrush="{StaticResource EveHairline}" BorderThickness="1"
                                CornerRadius="10" Padding="18,16">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"  Value="{StaticResource EveRaisedBg}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource EveAccentDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ WINDOW CONTROL BUTTON — frameless min/max/close dots ══ -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Width"            Value="32"/>
            <Setter Property="Height"           Value="28"/>
            <Setter Property="Foreground"       Value="{StaticResource EveTextSecondary}"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EveRaisedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ SMALL UPPERCASE SECTION LABEL ══ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <!-- ══ PAGE TITLE — big light-weight heading, matches the dashboard greeting ══ -->
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"   Value="26"/>
            <Setter Property="FontWeight" Value="Light"/>
        </Style>

        <!-- ══ PAGE EYEBROW — uppercase category above the title ══ -->
        <Style x:Key="PageEyebrow" TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ══ SLIM SCROLLBAR ══ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4" Background="#2b3545" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ DARK COMBOBOX ══ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter TextElement.Foreground="{StaticResource EveTextPrimary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14202e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Height"     Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="26"/>
                            </Grid.ColumnDefinitions>
                            <!-- Full-width background + open-on-click (sits behind everything) -->
                            <ToggleButton Grid.ColumnSpan="2" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="#0f1622" BorderBrush="{StaticResource EveHairlineStrong}"
                                                BorderThickness="1" CornerRadius="7"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource EveAccent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Selected item (non-editable) -->
                            <ContentPresenter x:Name="contentPresenter" Grid.Column="0" IsHitTestVisible="False"
                                              Margin="11,0,0,0" VerticalAlignment="Center"
                                              TextElement.Foreground="{StaticResource EveTextPrimary}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <!-- Editable text entry (shown only when IsEditable) -->
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Visibility="Collapsed"
                                     Margin="8,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     Foreground="{StaticResource EveTextPrimary}" CaretBrush="{StaticResource EveAccent}"/>
                            <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                                  Data="M 0 0 L 8 0 L 4 5 Z" Fill="{StaticResource EveTextSecondary}"/>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#0f1622" BorderBrush="{StaticResource EveHairlineStrong}" BorderThickness="1"
                                        CornerRadius="7" Margin="0,2,0,0" Padding="3"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="contentPresenter"     Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ PAGE → VIEW MAPPINGS ══ -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MenuViewModel}">
            <views:MenuView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IntelViewModel}">
            <views:IntelView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FleetViewModel}">
            <views:FleetView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionLogViewModel}">
            <views:SessionLogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PingViewModel}">
            <views:PingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlertsViewModel}">
            <views:AlertsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccountViewModel}">
            <views:AccountView/>
        </DataTemplate>

    </Application.Resources>
</Application>
