<UserControl x:Class="FCAT.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Dark themed text box -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#0f1622"/>
            <Setter Property="Foreground"      Value="{StaticResource EveTextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource EveAccent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource EveHairlineStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource EveAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="34,24,34,16">
            <TextBlock Text="CONFIGURATION" Style="{StaticResource PageEyebrow}"/>
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="34,0,34,24">
            <Border Style="{StaticResource Card}" HorizontalAlignment="Left" MaxWidth="640">
            <StackPanel Margin="28,24,28,24">

                <!-- EVE logs folder -->
                <TextBlock Text="EVE LOGS FOLDER" Style="{StaticResource SectionLabel}" Margin="0,0,0,7"/>
                <TextBlock Text="The folder containing your Gamelogs and Chatlogs (combat log + boost channels)."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                             Text="{Binding EveLogsPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Command="{Binding BrowseCommand}" Style="{StaticResource SecondaryButton}"
                            Padding="14,0" Margin="8,0,0,0">
                        <TextBlock Text="Browse…" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding ResetToDefaultCommand}" Style="{StaticResource GhostButton}"
                            Padding="10,0" Margin="4,0,0,0">
                        <TextBlock Text="Reset" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                    </Button>
                </Grid>

                <!-- Derived path checks -->
                <Border Background="{StaticResource EveRaisedBg}" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gamelogs -->
                        <Ellipse Grid.Row="0" Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,8">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource EveCritical}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GamelogsFound}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource EveGreen}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Gamelogs" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,8" Width="64"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding GamelogsPath}" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" VerticalAlignment="Center" Margin="0,0,0,8"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Chatlogs -->
                        <Ellipse Grid.Row="1" Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource EveCritical}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ChatlogsFound}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource EveGreen}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Chatlogs" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" Width="64"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ChatlogsPath}" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- Boost channel prefix -->
                <TextBlock Text="BOOST CHANNEL NAME" Style="{StaticResource SectionLabel}" Margin="0,0,0,7"/>
                <TextBlock Text="Filename prefix of the boost channel logs to read (default &quot;Boost&quot;)."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>
                <TextBox Style="{StaticResource DarkTextBox}" Width="220" HorizontalAlignment="Left"
                         Text="{Binding BoostChannelPrefix, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Intel channel prefix -->
                <TextBlock Text="INTEL CHANNEL NAME" Style="{StaticResource SectionLabel}" Margin="0,18,0,7"/>
                <TextBlock Text="Filename prefix of the in-game intel channel logs to read for the intel feed (default &quot;Intel&quot;). You must be joined to the channel in EVE."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>
                <TextBox Style="{StaticResource DarkTextBox}" Width="220" HorizontalAlignment="Left"
                         Text="{Binding IntelChannelPrefix, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Fleet form-up system (autocomplete) -->
                <TextBlock Text="FLEET FORM-UP SYSTEM" Style="{StaticResource SectionLabel}" Margin="0,24,0,7"/>
                <TextBlock Text="The system your fleet stages in. Used by the straggler check to flag pilots who aren't in it yet."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>
                <Grid Width="300" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- The box + its suggestion dropdown share column 0 -->
                    <StackPanel Grid.Column="0">
                        <TextBox x:Name="FormupBox" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FormupSystemText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type a system name and pick from the list"/>
                        <!-- Suggestions dropdown -->
                        <Border Background="#0f1622" BorderBrush="{StaticResource EveHairlineStrong}" BorderThickness="1"
                                CornerRadius="7" Margin="0,4,0,0" Padding="4"
                                Visibility="{Binding SystemSuggestions.Count, Converter={StaticResource CountToVisibility}}">
                            <ItemsControl ItemsSource="{Binding SystemSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.PickSystemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                                Height="28" Padding="8,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource EveTextSecondary}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="12"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ClearFormupCommand}" Style="{StaticResource GhostButton}"
                            Padding="10,0" Margin="6,0,0,0" VerticalAlignment="Top" Height="34" ToolTip="Clear">
                        <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource EveCritical}"/>
                    </Button>
                </Grid>
                <TextBlock Text="Building system list…" Foreground="{StaticResource EveTextDim}"
                           FontFamily="{StaticResource FontUI}" FontSize="10" Margin="0,5,0,0"
                           Visibility="{Binding SystemsLoading, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Alerts: auto-clear -->
                <TextBlock Text="ALERTS" Style="{StaticResource SectionLabel}" Margin="0,24,0,7"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Overlay auto-clear" Foreground="{StaticResource EveTextSecondary}"
                               FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Width="80"
                             TextAlignment="Center" MaxLength="5"
                             Text="{Binding AlertClearSecondsText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Seconds before an alert disappears from the on-screen overlay. The in-app Alerts list keeps it for the whole session. 0 = keep on the overlay too."/>
                    <TextBlock Grid.Column="2" Text="seconds  (0 = keep)" Foreground="{StaticResource EveTextDim}"
                               FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
                <TextBlock Text="{Binding AlertClearHint}"
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11" Margin="0,0,0,0"/>

                <!-- Alert overlay (on-screen, over the game) -->
                <TextBlock Text="ALERT OVERLAY" Style="{StaticResource SectionLabel}" Margin="0,18,0,7"/>
                <TextBlock Text="A small always-on-top window that shows alerts over your game. It stays up no matter which FCAT screen you're on, as long as a fleet is being monitored."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding Overlay.ToggleOverlayCommand}" Style="{StaticResource SecondaryButton}"
                            Height="34" Padding="16,0" Margin="0,0,8,0" ToolTip="Show / hide the on-screen alert overlay">
                        <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⧉ Overlay: OFF"/>
                                    <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Overlay.OverlayEnabled}" Value="True">
                                            <Setter Property="Text" Value="⧉ Overlay: ON"/>
                                            <Setter Property="Foreground" Value="{StaticResource EveAccent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding Overlay.ToggleOverlayLockCommand}" Style="{StaticResource SecondaryButton}"
                            Height="34" Padding="16,0" ToolTip="Lock makes the overlay click-through so it won't steal clicks from the game"
                            Visibility="{Binding Overlay.OverlayEnabled, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🔓 Unlocked"/>
                                    <Setter Property="Foreground" Value="{StaticResource EveAmber}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Overlay.OverlayLocked}" Value="True">
                                            <Setter Property="Text" Value="🔒 Locked"/>
                                            <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>

                <!-- Alert sounds -->
                <TextBlock Text="ALERT SOUNDS" Style="{StaticResource SectionLabel}" Margin="0,18,0,7"/>
                <TextBlock Text="Pick a tone per alert. Click a sound to cycle presets; ▶ to preview."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>

                <Button Command="{Binding ToggleSoundsCommand}" Style="{StaticResource SecondaryButton}"
                        Height="34" HorizontalAlignment="Left" Padding="16,0" Margin="0,0,0,12">
                    <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Alert sounds: OFF"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AlertSoundsEnabled}" Value="True">
                                        <Setter Property="Text" Value="Alert sounds: ON"/>
                                        <Setter Property="Foreground" Value="{StaticResource EveGreen}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <StackPanel IsEnabled="{Binding AlertSoundsEnabled}">
                    <!-- Tackled -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tackled (you)" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding CycleTackledCommand}" Style="{StaticResource SecondaryButton}"
                                Height="32" HorizontalContentAlignment="Left" Padding="12,0" Margin="0,0,8,0" ToolTip="Click to change sound">
                            <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12"><Run Text="♪  "/><Run Text="{Binding TackledSound}"/></TextBlock>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding TestTackledCommand}" Style="{StaticResource GhostButton}" Height="32" Padding="10,0" ToolTip="Preview">
                            <TextBlock Text="▶" FontSize="12" Foreground="{StaticResource EveAccent}"/>
                        </Button>
                    </Grid>
                    <!-- Cap out -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cap out" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding CycleCapTroubleCommand}" Style="{StaticResource SecondaryButton}"
                                Height="32" HorizontalContentAlignment="Left" Padding="12,0" Margin="0,0,8,0" ToolTip="Click to change sound">
                            <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12"><Run Text="♪  "/><Run Text="{Binding CapTroubleSound}"/></TextBlock>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding TestCapTroubleCommand}" Style="{StaticResource GhostButton}" Height="32" Padding="10,0" ToolTip="Preview">
                            <TextBlock Text="▶" FontSize="12" Foreground="{StaticResource EveAccent}"/>
                        </Button>
                    </Grid>
                    <!-- Boost lost -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Booster lost" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding CycleBoostLostCommand}" Style="{StaticResource SecondaryButton}"
                                Height="32" HorizontalContentAlignment="Left" Padding="12,0" Margin="0,0,8,0" ToolTip="Click to change sound">
                            <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12"><Run Text="♪  "/><Run Text="{Binding BoostLostSound}"/></TextBlock>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding TestBoostLostCommand}" Style="{StaticResource GhostButton}" Height="32" Padding="10,0" ToolTip="Preview">
                            <TextBlock Text="▶" FontSize="12" Foreground="{StaticResource EveAccent}"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Actions -->
                <!-- Demo / sandbox -->
                <Rectangle Height="1" Fill="{StaticResource EveHairline}" Margin="0,24,0,18"/>
                <TextBlock Text="DEMO / SANDBOX" Style="{StaticResource SectionLabel}" Margin="0,0,0,7"/>
                <TextBlock Text="Runs FCAT on a simulated fleet so you can try Fleet Ops, the dashboard and alerts without being in a live fleet. Intel still uses your real current system. Turn off to go back to live data."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,9"/>
                <Button Command="{Binding Shell.ToggleDemoCommand}" Style="{StaticResource SecondaryButton}"
                        Height="34" Padding="16,0" HorizontalAlignment="Left"
                        ToolTip="Simulate a fleet for testing / screenshots">
                    <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="🧪 Demo mode: OFF"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Shell.DemoMode}" Value="True">
                                        <Setter Property="Text" Value="🧪 Demo mode: ON"/>
                                        <Setter Property="Foreground" Value="{StaticResource EveAccent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Updates -->
                <Rectangle Height="1" Fill="{StaticResource EveHairline}" Margin="0,24,0,18"/>
                <TextBlock Text="UPDATES" Style="{StaticResource SectionLabel}" Margin="0,0,0,7"/>
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FCAT checks GitHub for new versions on launch."
                                   Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"/>
                        <TextBlock Text="{Binding Shell.UpdateStatus}" Foreground="{StaticResource EveAccent}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11" Margin="0,4,0,0"
                                   Visibility="{Binding Shell.UpdateStatus, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding Shell.CheckForUpdatesCommand}" Style="{StaticResource SecondaryButton}"
                                Height="34" Padding="14,0" Margin="0,0,8,0">
                            <TextBlock Text="Check for updates" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                        </Button>
                        <Button Command="{Binding Shell.ApplyUpdateCommand}" Style="{StaticResource PrimaryButton}"
                                Height="34" Padding="16,0"
                                Visibility="{Binding Shell.UpdateReady, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Restart &amp; update" FontFamily="{StaticResource FontUI}" FontSize="12" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,24,0,0">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource EveGreen}"
                               FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center"/>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"
                            Height="40" Width="150" HorizontalAlignment="Right">
                        <TextBlock Text="Save settings" FontFamily="{StaticResource FontUI}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>
                </Grid>
            </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
