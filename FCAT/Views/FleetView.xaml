<UserControl x:Class="FCAT.Views.FleetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             xmlns:models="clr-namespace:FCAT.Models"
             xmlns:local="clr-namespace:FCAT"
             d:DataContext="{d:DesignInstance vm:FleetViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:UrlToImageConverter x:Key="UrlToImage"/>

        <!-- Row hover — rounded, calm -->
        <Style x:Key="MemberRow" TargetType="Border">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="CornerRadius"  Value="6"/>
            <Setter Property="Padding"       Value="0,4"/>
            <Setter Property="Margin"        Value="6,1,8,1"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14202e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Role chip -->
        <Style x:Key="RoleChip" TargetType="Border">
            <Setter Property="CornerRadius"      Value="4"/>
            <Setter Property="Padding"           Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth"          Value="44"/>
        </Style>

        <!-- Row action button (kick / move) — hidden unless the row is manageable AND hovered -->
        <Style x:Key="RowActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CanManage}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Header action button (wing/squad add/rename/delete) — always visible, dim until hover -->
        <Style x:Key="HeaderActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark text box (invite field) -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#0f1622"/>
            <Setter Property="Foreground"      Value="{StaticResource EveTextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource EveAccent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource EveHairlineStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="9,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource EveAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════ TOP BAR ════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource EvePanelBg}"
                BorderBrush="{StaticResource EveHairline}" BorderThickness="0,0,0,1">
            <Grid Height="54" Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="FCAT"
                           Foreground="{StaticResource EveGold}"
                           FontFamily="{StaticResource FontUI}" FontSize="17" FontWeight="Light"
                           VerticalAlignment="Center"/>

                <Rectangle Grid.Column="1" Width="1" Height="20" Margin="14,0"
                           Fill="{StaticResource EveHairlineStrong}" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" Text="FLEET" Style="{StaticResource SectionLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="3" Text="{Binding FleetIdDisplay}"
                           Foreground="{StaticResource EveTextSecondary}"
                           FontFamily="{StaticResource FontMono}" FontSize="13"
                           VerticalAlignment="Center"/>

                <!-- Pilot count chip -->
                <Border Grid.Column="5" Background="{StaticResource EveRaisedBg}"
                        CornerRadius="6" Padding="11,5" Margin="0,0,16,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="{StaticResource EveGoldSoft}"
                                   FontFamily="{StaticResource FontUI}" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding MemberCount}"/>
                        </TextBlock>
                        <TextBlock Text=" pilots" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11"
                                   VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Live indicator -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0"
                            Visibility="{Binding IsLive, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0">
                        <Ellipse.Fill>
                            <SolidColorBrush x:Name="LiveDot" Color="#4db8d4"/>
                        </Ellipse.Fill>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="LiveDot"
                                                        Storyboard.TargetProperty="Color"
                                                        From="#4db8d4" To="#27566a" Duration="0:0:1.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="Live" Foreground="{StaticResource EveAccent}"
                               FontFamily="{StaticResource FontUI}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Overlay toggle -->
                <Button Grid.Column="7" Command="{Binding ToggleOverlayCommand}"
                        Style="{StaticResource GhostButton}" Padding="11,7" Margin="0,0,2,0"
                        ToolTip="Show an on-screen alert overlay over your game">
                    <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="⧉ Overlay"/>
                                <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OverlayEnabled}" Value="True">
                                        <Setter Property="Text"       Value="⧉ Overlay"/>
                                        <Setter Property="Foreground" Value="{StaticResource EveAccent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Lock toggle (only while overlay is shown) -->
                <Button Grid.Column="8" Command="{Binding ToggleOverlayLockCommand}"
                        Style="{StaticResource GhostButton}" Padding="11,7" Margin="0,0,2,0"
                        ToolTip="Lock makes the overlay click-through so it won't steal clicks"
                        Visibility="{Binding OverlayEnabled, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="🔓 Unlocked"/>
                                <Setter Property="Foreground" Value="{StaticResource EveAmber}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OverlayLocked}" Value="True">
                                        <Setter Property="Text"       Value="🔒 Locked"/>
                                        <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button Grid.Column="9" Command="{Binding BackToMenuCommand}"
                        Style="{StaticResource GhostButton}" Padding="13,7">
                    <TextBlock Text="← Menu" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- ════════════════════ FLEET-CHANGED BANNER ════════════════════ -->
        <Border Grid.Row="1" Background="#241803" BorderBrush="{StaticResource EveAmber}"
                BorderThickness="0,0,0,1" Padding="18,10"
                Visibility="{Binding FleetChangedWarning, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="{StaticResource EveAmber}"
                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="New fleet detected — ID " FontWeight="SemiBold"/>
                    <Run Text="{Binding NewDetectedFleetId}" FontWeight="SemiBold"/>
                    <Run Text=". This session is tracking the old fleet."/>
                </TextBlock>
                <Button Grid.Column="1" Command="{Binding SwitchToNewFleetCommand}"
                        Style="{StaticResource SecondaryButton}" Padding="13,5" BorderBrush="{StaticResource EveAmber}">
                    <TextBlock Text="Switch now" Foreground="{StaticResource EveAmber}"
                               FontFamily="{StaticResource FontUI}" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- ════════════════════ COMPOSITION + BOOST COVERAGE ════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource EvePanelBg}"
                BorderBrush="{StaticResource EveHairline}" BorderThickness="0,0,0,1"
                Padding="18,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Role tally -->
                <ItemsControl ItemsSource="{Binding RoleStats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FleetStat}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Count}" Foreground="{Binding Color}"
                                           FontFamily="{StaticResource FontUI}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource EveTextDim}"
                                           FontFamily="{StaticResource FontUI}" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Divider -->
                <Rectangle Width="1" Height="18" Fill="{StaticResource EveHairlineStrong}" Margin="4,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Text="LINKS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- Boost coverage -->
                <ItemsControl ItemsSource="{Binding BoostStats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:BoostStat}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}" Foreground="{Binding Color}"
                                           FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CountText}" Foreground="{Binding Color}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Mainline label + composition advisories -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding MainlineLabel}" Foreground="{StaticResource EveTextDim}"
                           FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                           Visibility="{Binding MainlineLabel, Converter={StaticResource StringToVisibility}}"/>
                <ItemsControl ItemsSource="{Binding Advisories}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FleetAdvisory}">
                            <Border Margin="6,0,0,0" Padding="8,2" CornerRadius="4"
                                    BorderThickness="1" BorderBrush="{Binding Color}" Background="#1a1118">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠" Foreground="{Binding Color}" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Text}" Foreground="{Binding Color}"
                                               FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════ MAIN ════════════════════ -->
        <Grid Grid.Row="3" Margin="14,12,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ───────── FLEET HIERARCHY ───────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar: invite + add wing -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource EveHairline}" BorderThickness="0,0,0,1"
                            Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" Width="200"
                                     Text="{Binding InviteName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Character name to invite">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding InviteCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Command="{Binding InviteCommand}" Style="{StaticResource SecondaryButton}"
                                    Padding="14,0" Margin="8,0,0,0" Height="32">
                                <TextBlock Text="Invite" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                            </Button>
                            <Button Grid.Column="3" Command="{Binding AddWingCommand}" Style="{StaticResource SecondaryButton}"
                                    Padding="12,0" Height="32" ToolTip="Add a new wing">
                                <TextBlock Text="＋ Wing" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Column header -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource EveHairline}" BorderThickness="0,0,0,1"
                            Padding="61,11,18,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="96"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PILOT"  Style="{StaticResource SectionLabel}"/>
                            <TextBlock Grid.Column="2" Text="SHIP"   Style="{StaticResource SectionLabel}"/>
                            <TextBlock Grid.Column="3" Text="SYSTEM" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Grid.Column="4" Text="ROLE"   Style="{StaticResource SectionLabel}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,6,0,10">
                        <StackPanel>

                            <!-- ░░ FLEET COMMAND ░░ -->
                            <ItemsControl ItemsSource="{Binding FleetCommandLevel}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FleetMemberViewModel}">
                                        <Border Style="{StaticResource MemberRow}">
                                            <Grid Margin="6,0,6,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="46"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="96"/>
                                                </Grid.ColumnDefinitions>

                                                <Rectangle Grid.Column="0" Width="3" RadiusX="1.5" RadiusY="1.5"
                                                           Fill="{StaticResource EveGold}" Margin="0,2"/>

                                                <Border Grid.Column="1" Width="34" Height="34" CornerRadius="9"
                                                        Background="#101a26" HorizontalAlignment="Center">
                                                    <Border CornerRadius="9">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding PortraitUrl, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill"/>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0,8,0">
                                                    <TextBlock Text="{Binding CharacterName}" Foreground="{StaticResource EveGoldSoft}"
                                                               FontFamily="{StaticResource FontUI}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Fleet Commander" Foreground="{StaticResource EveTextDim}"
                                                               FontFamily="{StaticResource FontUI}" FontSize="11" Margin="0,1,0,0"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0" ToolTip="{Binding BoostDetail}"
                                                                Visibility="{Binding HasBoosts, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="⚡ " Foreground="{StaticResource EveAccent}" FontSize="10" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding BoostSummary}" Foreground="{StaticResource EveAccent}"
                                                                   FontFamily="{StaticResource FontUI}" FontSize="10" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="PODDED" Foreground="{StaticResource EveCritical}" FontFamily="{StaticResource FontUI}"
                                                               FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"
                                                               Visibility="{Binding IsInCapsule, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>

                                                <Border Grid.Column="3" Width="30" Height="30" CornerRadius="7"
                                                        Background="#101a26" HorizontalAlignment="Center">
                                                    <Image Source="{Binding ShipIconUrl, Converter={StaticResource UrlToImage}}"
                                                           Stretch="Uniform" Margin="2" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>

                                                <TextBlock Grid.Column="4" Text="{Binding ShipTypeName}" Foreground="{StaticResource EveTextSecondary}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                                                <TextBlock Grid.Column="5" Text="{Binding SolarSystemName}" Foreground="{StaticResource EveTextDim}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>

                                                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Command="{Binding MoveCommand}" Style="{StaticResource RowActionButton}" ToolTip="Move to squad" Margin="0,0,2,0">
                                                        <TextBlock Text="⇄" FontSize="12" Foreground="{StaticResource EveAccent}"/>
                                                    </Button>
                                                    <Button Command="{Binding KickCommand}" Style="{StaticResource RowActionButton}" ToolTip="Kick from fleet" Margin="0,0,4,0">
                                                        <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource EveCritical}"/>
                                                    </Button>
                                                    <Border Style="{StaticResource RoleChip}" Background="{Binding RoleBadgeBrush}"
                                                            Visibility="{Binding RoleBadgeVisible, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding RoleBadge}" Foreground="#0b0e14"
                                                                   FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ░░ WINGS ░░ -->
                            <ItemsControl ItemsSource="{Binding Wings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:WingViewModel}">
                                        <StackPanel Margin="0,10,0,0">

                                            <!-- Wing label + hairline + actions -->
                                            <Grid Margin="14,0,14,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource EveGold}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <Rectangle Grid.Column="1" Height="1" Margin="12,0,12,0" VerticalAlignment="Center"
                                                           Fill="{StaticResource EveHairline}"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Button Style="{StaticResource HeaderActionButton}" ToolTip="Add squad to this wing"
                                                            Command="{Binding DataContext.AddSquadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="＋ squad" Foreground="{StaticResource EveTextSecondary}" FontFamily="{StaticResource FontUI}" FontSize="11"/>
                                                    </Button>
                                                    <Button Style="{StaticResource HeaderActionButton}" ToolTip="Rename this wing" Margin="2,0,0,0"
                                                            Command="{Binding DataContext.BeginRenameWingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="✎" Foreground="{StaticResource EveTextSecondary}" FontSize="12"/>
                                                    </Button>
                                                    <Button Style="{StaticResource HeaderActionButton}" ToolTip="Delete this wing" Margin="2,0,0,0"
                                                            Command="{Binding DataContext.DeleteWingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="✕" Foreground="{StaticResource EveCritical}" FontSize="12"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Wing commanders -->
                                            <ItemsControl ItemsSource="{Binding WingCommanders}" Margin="14,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:FleetMemberViewModel}">
                                                        <Border Style="{StaticResource MemberRow}">
                                                            <Grid Margin="6,0,6,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="46"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="44"/>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="96"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Rectangle Grid.Column="0" Width="3" RadiusX="1.5" RadiusY="1.5"
                                                                           Fill="{Binding RoleBadgeBrush}" Margin="0,2"
                                                                           Visibility="{Binding RoleBadgeVisible, Converter={StaticResource BoolToVisibility}}"/>

                                                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                                                                        Background="#101a26" HorizontalAlignment="Center">
                                                                    <Border CornerRadius="8">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding PortraitUrl, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                    </Border>
                                                                </Border>

                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0,8,0">
                                                                    <TextBlock Text="{Binding CharacterName}" Foreground="{StaticResource EveTextPrimary}"
                                                                               FontFamily="{StaticResource FontUI}" FontSize="13" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="Wing Commander" Foreground="{StaticResource EveTextDim}"
                                                                               FontFamily="{StaticResource FontUI}" FontSize="11" Margin="0,1,0,0"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0" ToolTip="{Binding BoostDetail}"
                                                                                Visibility="{Binding HasBoosts, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBlock Text="⚡ " Foreground="{StaticResource EveAccent}" FontSize="10" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding BoostSummary}" Foreground="{StaticResource EveAccent}"
                                                                                   FontFamily="{StaticResource FontUI}" FontSize="10" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="PODDED" Foreground="{StaticResource EveCritical}" FontFamily="{StaticResource FontUI}"
                                                                               FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"
                                                                               Visibility="{Binding IsInCapsule, Converter={StaticResource BoolToVisibility}}"/>
                                                                </StackPanel>

                                                                <Border Grid.Column="3" Width="28" Height="28" CornerRadius="7"
                                                                        Background="#101a26" HorizontalAlignment="Center">
                                                                    <Image Source="{Binding ShipIconUrl, Converter={StaticResource UrlToImage}}"
                                                                           Stretch="Uniform" Margin="2" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                </Border>

                                                                <TextBlock Grid.Column="4" Text="{Binding ShipTypeName}" Foreground="{StaticResource EveTextSecondary}"
                                                                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                                                                <TextBlock Grid.Column="5" Text="{Binding SolarSystemName}" Foreground="{StaticResource EveTextDim}"
                                                                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>

                                                                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                    <Button Command="{Binding MoveCommand}" Style="{StaticResource RowActionButton}" ToolTip="Move to squad" Margin="0,0,2,0">
                                                                        <TextBlock Text="⇄" FontSize="12" Foreground="{StaticResource EveAccent}"/>
                                                                    </Button>
                                                                    <Button Command="{Binding KickCommand}" Style="{StaticResource RowActionButton}" ToolTip="Kick from fleet" Margin="0,0,4,0">
                                                                        <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource EveCritical}"/>
                                                                    </Button>
                                                                    <Border Style="{StaticResource RoleChip}" Background="{Binding RoleBadgeBrush}"
                                                                            Visibility="{Binding RoleBadgeVisible, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBlock Text="{Binding RoleBadge}" Foreground="#0b0e14"
                                                                                   FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Squads -->
                                            <ItemsControl ItemsSource="{Binding Squads}" Margin="14,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:SquadViewModel}">
                                                        <StackPanel Margin="0,4,0,0">

                                                            <Grid Margin="14,4,8,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource EveTextDim}"
                                                                           FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <Button Style="{StaticResource HeaderActionButton}" ToolTip="Rename this squad"
                                                                            Command="{Binding DataContext.BeginRenameSquadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}">
                                                                        <TextBlock Text="✎" Foreground="{StaticResource EveTextDim}" FontSize="11"/>
                                                                    </Button>
                                                                    <Button Style="{StaticResource HeaderActionButton}" ToolTip="Delete this squad" Margin="2,0,0,0"
                                                                            Command="{Binding DataContext.DeleteSquadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}">
                                                                        <TextBlock Text="✕" Foreground="{StaticResource EveCritical}" FontSize="11"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>

                                                            <ItemsControl ItemsSource="{Binding Members}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type vm:FleetMemberViewModel}">
                                                                        <Border Style="{StaticResource MemberRow}">
                                                                            <Grid Margin="6,0,6,0">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="3"/>
                                                                                    <ColumnDefinition Width="46"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="44"/>
                                                                                    <ColumnDefinition Width="150"/>
                                                                                    <ColumnDefinition Width="90"/>
                                                                                    <ColumnDefinition Width="96"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <Rectangle Grid.Column="0" Width="3" RadiusX="1.5" RadiusY="1.5"
                                                                                           Fill="{Binding RoleBadgeBrush}" Margin="0,2"
                                                                                           Visibility="{Binding RoleBadgeVisible, Converter={StaticResource BoolToVisibility}}"/>

                                                                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                                                                                        Background="#101a26" HorizontalAlignment="Center">
                                                                                    <Border CornerRadius="8">
                                                                                        <Border.Background>
                                                                                            <ImageBrush ImageSource="{Binding PortraitUrl, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill"/>
                                                                                        </Border.Background>
                                                                                    </Border>
                                                                                </Border>

                                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0,8,0">
                                                                                    <TextBlock Text="{Binding CharacterName}" FontFamily="{StaticResource FontUI}" FontSize="13">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Foreground" Value="{StaticResource EveTextPrimary}"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsSquadCommander}" Value="True">
                                                                                                        <Setter Property="Foreground" Value="{StaticResource EveAmber}"/>
                                                                                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                    <TextBlock Text="Squad Lead" Foreground="{StaticResource EveAmber}"
                                                                                               FontFamily="{StaticResource FontUI}" FontSize="10" Margin="0,1,0,0"
                                                                                               Visibility="{Binding IsSquadCommander, Converter={StaticResource BoolToVisibility}}"/>
                                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0" ToolTip="{Binding BoostDetail}"
                                                                                                Visibility="{Binding HasBoosts, Converter={StaticResource BoolToVisibility}}">
                                                                                        <TextBlock Text="⚡ " Foreground="{StaticResource EveAccent}" FontSize="10" VerticalAlignment="Center"/>
                                                                                        <TextBlock Text="{Binding BoostSummary}" Foreground="{StaticResource EveAccent}"
                                                                                                   FontFamily="{StaticResource FontUI}" FontSize="10" VerticalAlignment="Center"/>
                                                                                    </StackPanel>
                                                                                    <TextBlock Text="PODDED" Foreground="{StaticResource EveCritical}" FontFamily="{StaticResource FontUI}"
                                                                                               FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"
                                                                                               Visibility="{Binding IsInCapsule, Converter={StaticResource BoolToVisibility}}"/>
                                                                                </StackPanel>

                                                                                <Border Grid.Column="3" Width="28" Height="28" CornerRadius="7"
                                                                                        Background="#101a26" HorizontalAlignment="Center">
                                                                                    <Image Source="{Binding ShipIconUrl, Converter={StaticResource UrlToImage}}"
                                                                                           Stretch="Uniform" Margin="2" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                                </Border>

                                                                                <TextBlock Grid.Column="4" Text="{Binding ShipTypeName}" Foreground="{StaticResource EveTextSecondary}"
                                                                                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                                                                                <TextBlock Grid.Column="5" Text="{Binding SolarSystemName}" Foreground="{StaticResource EveTextDim}"
                                                                                           FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>

                                                                                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                                    <Button Command="{Binding MoveCommand}" Style="{StaticResource RowActionButton}" ToolTip="Move to squad" Margin="0,0,2,0">
                                                                                        <TextBlock Text="⇄" FontSize="12" Foreground="{StaticResource EveAccent}"/>
                                                                                    </Button>
                                                                                    <Button Command="{Binding KickCommand}" Style="{StaticResource RowActionButton}" ToolTip="Kick from fleet" Margin="0,0,4,0">
                                                                                        <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource EveCritical}"/>
                                                                                    </Button>
                                                                                    <Border Style="{StaticResource RoleChip}" Background="{Binding RoleBadgeBrush}"
                                                                                            Visibility="{Binding RoleBadgeVisible, Converter={StaticResource BoolToVisibility}}">
                                                                                        <TextBlock Text="{Binding RoleBadge}" Foreground="#0b0e14"
                                                                                                   FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold"
                                                                                                   HorizontalAlignment="Center"/>
                                                                                    </Border>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ───────── ALERTS ───────── -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource EveHairline}" BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource EveCritical}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="ALERTS" Style="{StaticResource SectionLabel}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                        ToolTip="Boost channel being read from your EVE Chatlogs">
                                <TextBlock Text="⚡" Foreground="{StaticResource EveAccent}" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding BoostChannelName}" Foreground="{StaticResource EveTextDim}"
                                           FontFamily="{StaticResource FontMono}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding Alerts.Count, Converter={StaticResource CountToInvisibility}}">
                        <TextBlock Text="All clear" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="Watching combat log for tackle" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Alerts}" Margin="10,10,10,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FcAlert}">
                                    <Border Margin="0,0,0,8" Opacity="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"      Value="{StaticResource EveRaisedBg}"/>
                                                <Setter Property="BorderBrush"     Value="{StaticResource EveHairline}"/>
                                                <Setter Property="BorderThickness" Value="1,1,1,1"/>
                                                <Setter Property="CornerRadius"    Value="8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                        <Setter Property="Background"  Value="#1c1012"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource EveCritical}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22">
                                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <ThicknessAnimation Storyboard.TargetProperty="Margin" From="16,0,0,8" To="0,0,0,8" Duration="0:0:0.22">
                                                            <ThicknessAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                                                        </ThicknessAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>

                                        <Grid Margin="12,10,12,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Width="3" RadiusX="1.5" RadiusY="1.5" Margin="0,1,10,1">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Fill" Value="{StaticResource EveAmber}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource EveCritical}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding AlertTag}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource EveAmber}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource EveCritical}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Headline}" Foreground="{StaticResource EveTextPrimary}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="13" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SubText}" Foreground="{StaticResource EveTextSecondary}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                                           Visibility="{Binding SubText, Converter={StaticResource StringToVisibility}}"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" Foreground="{StaticResource EveTextDim}"
                                                           FontFamily="{StaticResource FontMono}" FontSize="11" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════ MOVE PICKER OVERLAY ════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#b0050810"
              Visibility="{Binding IsMovePickerOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Width="360" MaxHeight="440"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="22,20,22,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="MOVE PILOT" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding MovePilotName}" Foreground="{StaticResource EveTextPrimary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="16" FontWeight="SemiBold" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MoveTargets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:MoveTargetViewModel}">
                                    <Button Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,0,6"
                                            HorizontalContentAlignment="Left" Padding="12,0"
                                            Command="{Binding DataContext.MoveToCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding Label}" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Command="{Binding CancelMoveCommand}" Style="{StaticResource GhostButton}"
                            Height="32" Margin="0,12,0,0">
                        <TextBlock Text="Cancel" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════ RENAME OVERLAY ════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#b0050810"
              Visibility="{Binding IsRenameOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Width="340"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Margin="22,20,22,18">
                    <TextBlock Text="{Binding RenameTitle}" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ConfirmRenameCommand}"/>
                            <KeyBinding Key="Esc"    Command="{Binding CancelRenameCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Grid Margin="0,16,0,0">
                        <Button Command="{Binding CancelRenameCommand}" Style="{StaticResource GhostButton}"
                                Height="34" Width="90" HorizontalAlignment="Left">
                            <TextBlock Text="Cancel" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                        </Button>
                        <Button Command="{Binding ConfirmRenameCommand}" Style="{StaticResource PrimaryButton}"
                                Height="34" Width="110" HorizontalAlignment="Right">
                            <TextBlock Text="Rename" FontFamily="{StaticResource FontUI}" FontSize="12" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
