<UserControl x:Class="FCAT.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="Transparent">

        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="400">
            <StackPanel Margin="44,46,44,40">

                <!-- Wordmark -->
                <TextBlock Text="FCAT"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource EveGold}"
                           FontFamily="{StaticResource FontUI}" FontSize="46" FontWeight="Light"/>
                <TextBlock Text="Fleet Commander Assistance Tool"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource EveTextDim}"
                           FontFamily="{StaticResource FontUI}" FontSize="11"
                           Margin="0,4,0,0"/>

                <Rectangle Height="1" Margin="40,22,40,30" Fill="{StaticResource EveHairline}"/>

                <!-- Auth button -->
                <Button Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InvertBool}}"
                        Style="{StaticResource PrimaryButton}"
                        Height="46">
                    <TextBlock FontFamily="{StaticResource FontUI}" FontSize="13" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Log in with EVE Online"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                        <Setter Property="Text" Value="Waiting for browser…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource EveCritical}"
                           FontFamily="{StaticResource FontUI}" FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <TextBlock Text="Opens your browser · No passwords stored locally"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource EveTextDim}"
                           FontFamily="{StaticResource FontUI}" FontSize="11"
                           Margin="0,24,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Text="v1.0 · EVE ESI"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Foreground="{StaticResource EveTextDim}"
                   FontFamily="{StaticResource FontMono}" FontSize="10"
                   Margin="0,0,16,12"/>
    </Grid>
</UserControl>
