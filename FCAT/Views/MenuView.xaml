<UserControl x:Class="FCAT.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FCAT"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             d:DataContext="{d:DesignInstance vm:MenuViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="Transparent">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,26,40,32" MaxWidth="1320" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- greeting -->
                <RowDefinition Height="Auto"/>   <!-- char + fleet cards -->
                <RowDefinition Height="Auto"/>   <!-- feature cards -->
            </Grid.RowDefinitions>

            <!-- ════════ GREETING ════════ -->
            <StackPanel Grid.Row="0" Margin="2,0,0,22">
                <TextBlock Text="COMMAND CENTER" Style="{StaticResource SectionLabel}"
                           Foreground="{StaticResource EveTextDim}" Margin="0,0,0,4"/>
                <TextBlock FontFamily="{StaticResource FontUI}" FontSize="28" FontWeight="Light">
                    <Run Text="Good hunting, " Foreground="{StaticResource EveTextPrimary}"/><Run
                         Text="{Binding FirstName, Mode=OneWay}" Foreground="{StaticResource EveGoldSoft}" FontWeight="SemiBold"/><Run
                         Text="." Foreground="{StaticResource EveTextPrimary}"/>
                </TextBlock>
            </StackPanel>

            <!-- ════════ CHARACTER + FLEET ════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Character card ── -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="22,24">
                    <StackPanel>
                        <Border Width="92" Height="92" CornerRadius="46" Background="#0f1622"
                                HorizontalAlignment="Center"
                                BorderBrush="{StaticResource EveHairlineStrong}" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="{Binding CharacterName}" Foreground="{StaticResource EveGoldDim}"
                                           FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <Border CornerRadius="46">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding PortraitUrl, Converter={StaticResource UrlToImage}}"
                                                    Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding CharacterName}" Foreground="{StaticResource EveTextPrimary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <TextBlock Text="{Binding CharacterSubtitle}" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>

                        <Rectangle Height="1" Fill="{StaticResource EveHairline}" Margin="0,18,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SecurityStatusText}" Foreground="{StaticResource EveGreen}"
                                           FontFamily="{StaticResource FontUI}" FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="SEC STATUS" Style="{StaticResource SectionLabel}"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentSystemName}" Foreground="{StaticResource EveTextPrimary}"
                                           FontFamily="{StaticResource FontUI}" FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="CURRENT SYSTEM" Style="{StaticResource SectionLabel}"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Fleet card ── -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="26,22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- status header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,9,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource EveTextDim}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInFleet}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource EveGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontFamily="{StaticResource FontUI}" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="NO FLEET DETECTED"/>
                                        <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInFleet}" Value="True">
                                                <Setter Property="Text" Value="FLEET DETECTED"/>
                                                <Setter Property="Foreground" Value="{StaticResource EveGreen}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCheckingFleet}" Value="True">
                                                <Setter Property="Text" Value="QUERYING ESI…"/>
                                                <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- body: in-fleet detail -->
                        <Grid Grid.Row="1" Margin="0,14,0,16"
                              Visibility="{Binding IsInFleet, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top">
                                <TextBlock Text="{Binding PilotCount}" Foreground="{StaticResource EveTextPrimary}"
                                           FontFamily="{StaticResource FontUI}" FontSize="46" FontWeight="Light"
                                           VerticalAlignment="Center"/>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="pilots in fleet" Foreground="{StaticResource EveTextSecondary}"
                                               FontFamily="{StaticResource FontUI}" FontSize="13"/>
                                    <TextBlock Text="{Binding FleetCompositionText}" Foreground="{StaticResource EveTextDim}"
                                               FontFamily="{StaticResource FontUI}" FontSize="12" Margin="0,3,0,0"/>
                                    <TextBlock Text="{Binding FormingText}" Foreground="{StaticResource EveTextDim}"
                                               FontFamily="{StaticResource FontUI}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding OwnRoleText}" Foreground="{StaticResource EveGoldSoft}"
                                           FontFamily="{StaticResource FontUI}" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="YOUR ROLE" Style="{StaticResource SectionLabel}"
                                           HorizontalAlignment="Right" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- body: no-fleet hint -->
                        <StackPanel Grid.Row="1" Margin="0,16,0,16" VerticalAlignment="Center"
                                    Visibility="{Binding IsInFleet, Converter={StaticResource BoolToInvisibility}}">
                            <TextBlock Text="Form your fleet in EVE, then refresh to detect it here."
                                       Foreground="{StaticResource EveTextSecondary}"
                                       FontFamily="{StaticResource FontUI}" FontSize="13"/>
                        </StackPanel>

                        <!-- CTA row -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding EnterFleetCommand}" IsEnabled="{Binding IsInFleet}"
                                    Style="{StaticResource PrimaryButton}" Height="46">
                                <TextBlock Text="ENTER FLEET OPS  →" FontFamily="{StaticResource FontUI}"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding RefreshFleetStatusCommand}"
                                    Style="{StaticResource SecondaryButton}" Height="46" Padding="18,0">
                                <TextBlock Text="↻  Refresh" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════════ LIVE STATUS TILES ════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── READINESS (→ Fleet Ops) ── -->
                <Button Grid.Column="0" Style="{StaticResource FeatureCardButton}" Command="{Binding EnterFleetCommand}"
                        IsEnabled="{Binding IsInFleet}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="⧉  READINESS" Style="{StaticResource SectionLabel}"
                                       Foreground="{StaticResource EveTextSecondary}" HorizontalAlignment="Left"/>
                            <TextBlock Text="→" Foreground="{StaticResource EveTextDim}" FontSize="14" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- in-fleet stats -->
                        <Grid Visibility="{Binding IsInFleet, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding LogiText}" FontFamily="{StaticResource FontUI}" FontSize="18" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource EveGreen}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LogiLow}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource EveCritical}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="LOGI" Style="{StaticResource SectionLabel}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding TackleText}" FontFamily="{StaticResource FontUI}" FontSize="18" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasTackle}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource EveGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="TACKLE" Style="{StaticResource SectionLabel}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding BoosterText}" FontFamily="{StaticResource FontUI}" FontSize="18" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasBoosters}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource EveGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="BOOST" Style="{StaticResource SectionLabel}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="No fleet to assess" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12"
                                   Visibility="{Binding IsInFleet, Converter={StaticResource BoolToInvisibility}}"/>
                    </StackPanel>
                </Button>

                <!-- ── THREAT (→ Intel) ── -->
                <Button Grid.Column="2" Style="{StaticResource FeatureCardButton}" Command="{Binding OpenDScanCommand}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="◎  THREAT" Style="{StaticResource SectionLabel}"
                                       Foreground="{StaticResource EveTextSecondary}" HorizontalAlignment="Left"/>
                            <TextBlock Text="→" Foreground="{StaticResource EveTextDim}" FontSize="14" HorizontalAlignment="Right"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentSystemName}" Foreground="{StaticResource EveTextPrimary}"
                                       FontFamily="{StaticResource FontUI}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border CornerRadius="4" Padding="6,1" Margin="9,0,0,0" VerticalAlignment="Center"
                                    Background="{StaticResource EveRaisedBg}"
                                    Visibility="{Binding ThreatIsHot, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding ThreatActivityText}" Foreground="{StaticResource EveCritical}"
                                           FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding ThreatKillsText}" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- ── LAST ALERT (→ After-Action Report) ── -->
                <Button Grid.Column="4" Style="{StaticResource FeatureCardButton}" Command="{Binding OpenSessionLogCommand}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="⚠  LAST ALERT" Style="{StaticResource SectionLabel}"
                                       Foreground="{StaticResource EveTextSecondary}" HorizontalAlignment="Left"/>
                            <TextBlock Text="→" Foreground="{StaticResource EveTextDim}" FontSize="14" HorizontalAlignment="Right"/>
                        </Grid>
                        <!-- has an alert -->
                        <StackPanel Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding LatestAlert.Headline}" Foreground="{StaticResource EveTextPrimary}"
                                       FontFamily="{StaticResource FontUI}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding LatestAlert.SubText}" Foreground="{StaticResource EveTextSecondary}"
                                       FontFamily="{StaticResource FontUI}" FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Text="None this session" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12"
                                   Visibility="{Binding HasAlerts, Converter={StaticResource BoolToInvisibility}}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>
</UserControl>
