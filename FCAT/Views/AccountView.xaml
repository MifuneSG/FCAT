<UserControl x:Class="FCAT.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             d:DataContext="{d:DesignInstance vm:AccountViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Loaded="OnLoaded" Unloaded="OnUnloaded">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" Margin="34,24,34,16">
          <Grid MaxWidth="980" HorizontalAlignment="Center">
            <StackPanel VerticalAlignment="Bottom">
                <TextBlock Text="ACCOUNT" Style="{StaticResource PageEyebrow}"/>
                <TextBlock Text="Characters" Style="{StaticResource PageTitle}"/>
            </StackPanel>
            <Button Command="{Binding AddCharacterCommand}" Style="{StaticResource PrimaryButton}"
                    Height="38" Padding="18,0" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock FontFamily="{StaticResource FontUI}" FontSize="13" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="＋  Add character"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAdding}" Value="True">
                                    <Setter Property="Text" Value="Waiting for browser…"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>
          </Grid>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="34,0,34,24">
            <StackPanel MaxWidth="980" HorizontalAlignment="Center">

                <!-- Empty state -->
                <Border Style="{StaticResource Card}" Padding="26,30"
                        Visibility="{Binding Characters.Count, Converter={StaticResource CountToInvisibility}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No characters yet" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="Add your main and any alts (cyno, scout, hauler…) to see them here."
                                   Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Characters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CharacterRow}">
                            <Border Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>   <!-- portrait -->
                                        <ColumnDefinition Width="210"/>    <!-- name + role -->
                                        <ColumnDefinition Width="*"/>      <!-- status -->
                                        <ColumnDefinition Width="Auto"/>   <!-- actions -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Portrait -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Margin="0,0,14,0"
                                            Background="#0f1622" BorderBrush="{StaticResource EveHairlineStrong}" BorderThickness="1">
                                        <Border CornerRadius="22">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding PortraitUrl, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                    </Border>

                                    <!-- Name + role -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource EveTextPrimary}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border CornerRadius="4" Background="#2a2410" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="ACTIVE" Foreground="{StaticResource EveGoldSoft}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="9" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <ComboBox Margin="0,6,0,0" Width="150" HorizontalAlignment="Left"
                                                  ItemsSource="{Binding DataContext.RoleOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  SelectedItem="{Binding Role, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <!-- Status: online · system · ship -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource EveTextDim}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Online}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource EveGreen}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Offline"/>
                                                        <Setter Property="Foreground" Value="{StaticResource EveTextDim}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Online}" Value="True">
                                                                <Setter Property="Text" Value="Online"/>
                                                                <Setter Property="Foreground" Value="{StaticResource EveTextSecondary}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="16,5,0,0">
                                            <TextBlock Text="{Binding SystemName}" Foreground="{StaticResource EveTextPrimary}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="·" Foreground="{StaticResource EveTextDim}" Margin="7,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ShipName}" Foreground="{StaticResource EveTextSecondary}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="16,4,0,0">
                                            <TextBlock Text="{Binding DockText}" Foreground="{StaticResource EveTextDim}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center"
                                                       Visibility="{Binding DockText, Converter={StaticResource StringToVisibility}}"/>
                                            <Border CornerRadius="4" Background="#16221c" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding FleetText, Converter={StaticResource StringToVisibility}}">
                                                <TextBlock Text="{Binding FleetText}" Foreground="{StaticResource EveGreen}"
                                                           FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.SetActiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}"
                                                Height="32" Padding="14,0" Margin="0,0,8,0"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToInvisibility}}">
                                            <TextBlock Text="Set active" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Style="{StaticResource GhostButton}"
                                                Height="32" Padding="10,0" ToolTip="Remove this character from FCAT">
                                            <TextBlock Text="✕" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Status (online · system · ship) is read live from ESI for each character. Location is the system the character is in — not Local, grid, or d-scan."
                           Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11"
                           TextWrapping="Wrap" Margin="2,8,0,0"
                           Visibility="{Binding Characters.Count, Converter={StaticResource CountToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
