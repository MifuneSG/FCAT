<UserControl x:Class="FCAT.Views.DScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             d:DataContext="{d:DesignInstance vm:DScanViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="Transparent">
        <Border Style="{StaticResource Card}" Width="640" MaxHeight="680"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Margin="26,22,26,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Intel Tools" Foreground="{StaticResource EveTextPrimary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="18" FontWeight="Light"/>
                        <Rectangle Width="1" Height="16" Margin="12,0" Fill="{StaticResource EveHairlineStrong}" VerticalAlignment="Center"/>
                        <TextBlock Text="Directional scan" Foreground="{StaticResource EveTextDim}"
                                   FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Command="{Binding BackCommand}" Style="{StaticResource GhostButton}"
                            Padding="12,6" HorizontalAlignment="Right">
                        <TextBlock Text="← Back" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                    </Button>
                </Grid>

                <!-- Paste box -->
                <Border Grid.Row="1" Background="#0f1622" BorderBrush="{StaticResource EveHairlineStrong}"
                        BorderThickness="1" CornerRadius="7" Height="110">
                    <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource EveTextPrimary}"
                             CaretBrush="{StaticResource EveAccent}" FontFamily="{StaticResource FontMono}" FontSize="11"
                             Padding="10,8" AcceptsReturn="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Actions + summary -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock Text="{Binding Summary}" Foreground="{StaticResource EveTextDim}"
                               FontFamily="{StaticResource FontUI}" FontSize="11" VerticalAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,190,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding ClearCommand}" Style="{StaticResource GhostButton}"
                                Padding="14,0" Height="34" Margin="0,0,8,0">
                            <TextBlock Text="Clear" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                        </Button>
                        <Button Command="{Binding CopySummaryCommand}" Style="{StaticResource SecondaryButton}"
                                Padding="14,0" Height="34" Margin="0,0,8,0">
                            <TextBlock Text="Copy for comms" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                        </Button>
                        <Button Command="{Binding AnalyzeCommand}" Style="{StaticResource PrimaryButton}"
                                Padding="20,0" Height="34">
                            <TextBlock Text="Analyze" FontFamily="{StaticResource FontUI}" FontSize="12" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Role breakdown -->
                <ItemsControl Grid.Row="3" ItemsSource="{Binding RoleBreakdown}" Margin="0,18,0,0"
                              Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FleetStat}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Count}" Foreground="{Binding Color}"
                                           FontFamily="{StaticResource FontUI}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource EveTextDim}"
                                           FontFamily="{StaticResource FontUI}" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ship list -->
                <Border Grid.Row="4" BorderBrush="{StaticResource EveHairline}" BorderThickness="0,1,0,0"
                        Margin="0,6,0,0" Padding="0,10,0,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Ships}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DScanShip}">
                                    <Grid Margin="0,0,6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Foreground="{StaticResource EveTextPrimary}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="SemiBold">
                                            <Run Text="{Binding Count, Mode=OneWay}"/><Run Text="×"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding TypeName}" Foreground="{StaticResource EveTextSecondary}"
                                                   FontFamily="{StaticResource FontUI}" FontSize="12" VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" CornerRadius="4" Padding="6,1" Background="{Binding Color}">
                                            <TextBlock Text="{Binding RoleTag}" Foreground="#0b0e14"
                                                       FontFamily="{StaticResource FontUI}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
