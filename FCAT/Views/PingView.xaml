<UserControl x:Class="FCAT.Views.PingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             xmlns:models="clr-namespace:FCAT.Models"
             d:DataContext="{d:DesignInstance vm:PingViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#0f1622"/>
            <Setter Property="Foreground"      Value="{StaticResource EveTextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource EveAccent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource EveHairlineStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="9,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource EveAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EveTextSecondary}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,10,0,3"/>
        </Style>

        <!-- Suggestions dropdown container -->
        <Style x:Key="SuggestBox" TargetType="Border">
            <Setter Property="Background"      Value="#0f1622"/>
            <Setter Property="BorderBrush"     Value="{StaticResource EveHairlineStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="7"/>
            <Setter Property="Margin"          Value="0,4,0,0"/>
            <Setter Property="Padding"         Value="4"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="34,24,34,16">
            <StackPanel VerticalAlignment="Bottom">
                <TextBlock Text="BROADCAST" Style="{StaticResource PageEyebrow}"/>
                <TextBlock Text="Ping / MOTD" Style="{StaticResource PageTitle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock Text="PROFILE" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="150" Height="30" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="34,0,34,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ════════ INPUTS ════════ -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,16">
                    <StackPanel>
                        <TextBlock Text="PING DETAILS" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>

                        <TextBlock Text="Hurf — hype / explanation" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                 Text="{Binding Hurf, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="FC name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding FcName, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Forming (autocomplete, shared with Settings) -->
                        <TextBlock Text="Forming (system)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FormupBox" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FormupText, UpdateSourceTrigger=PropertyChanged}"/>
                        <Border Style="{StaticResource SuggestBox}"
                                Visibility="{Binding SystemSuggestions.Count, Converter={StaticResource CountToVisibility}}">
                            <ItemsControl ItemsSource="{Binding SystemSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.PickSystemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Style="{StaticResource GhostButton}"
                                                HorizontalContentAlignment="Left" Height="26" Padding="8,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource EveTextSecondary}" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Comms — editable dropdown (pick from the profile or type your own) -->
                        <TextBlock Text="Comms" Style="{StaticResource FieldLabel}"/>
                        <ComboBox IsEditable="True" StaysOpenOnEdit="True" ItemsSource="{Binding CommsOptions}"
                                  Text="{Binding CommsText, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Doctrine / Ships / Implants — alliance-specific (hidden on Custom) -->
                        <StackPanel Visibility="{Binding IsAlliance, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Doctrine" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Doctrines}" SelectedItem="{Binding SelectedDoctrine}">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Ships (priority order)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Ships, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Implants" Style="{StaticResource FieldLabel}"/>
                            <Button Command="{Binding ToggleImplantsCommand}" Style="{StaticResource SecondaryButton}" Height="32"
                                    HorizontalAlignment="Left" HorizontalContentAlignment="Left" Padding="16,0" MinWidth="90">
                                <TextBlock Text="{Binding ImplantsText}" FontFamily="{StaticResource FontUI}" FontSize="12"/>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="Fittings" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Fittings, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Main anchor" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding MainAnchor, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Type the exact character name — auto-links in the MOTD"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Logi anchor" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding LogiAnchor, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Type the exact character name — auto-links in the MOTD"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Height="48" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalContentAlignment="Top" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Channel links — alliance-specific (hidden on Custom) -->
                        <StackPanel Visibility="{Binding IsAlliance, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="CHANNEL LINKS (clickable in MOTD)" Style="{StaticResource SectionLabel}" Margin="0,18,0,4"/>
                            <TextBlock Text="Pick the boost / logi channel for this fleet — the clickable link drops into the MOTD."
                                       Foreground="{StaticResource EveTextDim}" FontFamily="{StaticResource FontUI}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Boosts" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Height="30" ItemsSource="{Binding BoostLinks}" SelectedItem="{Binding SelectedBoost}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Label}"/></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Logi" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Height="30" ItemsSource="{Binding LogiLinks}" SelectedItem="{Binding SelectedLogi}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Label}"/></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ════════ OUTPUTS ════════ -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid Margin="18,16,18,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Ping -->
                    <Grid Grid.Row="0">
                        <TextBlock Text="PING" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                        <Button Command="{Binding CopyPingCommand}" Style="{StaticResource SecondaryButton}" Height="28" Padding="12,0" HorizontalAlignment="Right">
                            <TextBlock Text="Copy ping" FontFamily="{StaticResource FontUI}" FontSize="11"/>
                        </Button>
                    </Grid>
                    <Border Grid.Row="1" Background="#0c1018" BorderBrush="{StaticResource EveHairlineStrong}" BorderThickness="1" CornerRadius="7" Margin="0,6,0,12">
                        <TextBox Text="{Binding PingText, Mode=OneWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource EveTextPrimary}" FontFamily="{StaticResource FontMono}" FontSize="12"
                                 Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <!-- MOTD -->
                    <Grid Grid.Row="2">
                        <TextBlock Text="MOTD" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CopyMotdCommand}" Style="{StaticResource SecondaryButton}" Height="28" Padding="12,0" Margin="0,0,8,0">
                                <TextBlock Text="Copy MOTD" FontFamily="{StaticResource FontUI}" FontSize="11"/>
                            </Button>
                            <Button Command="{Binding SetMotdOnFleetCommand}" Style="{StaticResource PrimaryButton}" Height="28" Padding="12,0"
                                    ToolTip="Push this MOTD to your current fleet (requires fleet boss)">
                                <TextBlock Text="Set on fleet" FontFamily="{StaticResource FontUI}" FontSize="11" FontWeight="SemiBold"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="3" Background="#0c1018" BorderBrush="{StaticResource EveHairlineStrong}" BorderThickness="1" CornerRadius="7" Margin="0,6,0,0">
                        <TextBox Text="{Binding MotdText, Mode=OneWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource EveTextPrimary}" FontFamily="{StaticResource FontMono}" FontSize="12"
                                 Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="{StaticResource EveGreen}"
                               FontFamily="{StaticResource FontUI}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
