<UserControl x:Class="FCAT.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FCAT.ViewModels"
             xmlns:models="clr-namespace:FCAT.Models"
             d:DataContext="{d:DesignInstance vm:AlertsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" Margin="34,24,34,16">
            <StackPanel VerticalAlignment="Bottom">
                <TextBlock Text="SESSION" Style="{StaticResource PageEyebrow}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Session Alerts" Style="{StaticResource PageTitle}"/>
                    <Border CornerRadius="9" Background="{StaticResource EveRaisedBg}" Padding="8,2" Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding Alerts.Count, Converter={StaticResource CountToVisibility}}">
                        <TextBlock Text="{Binding Alerts.Count}" Foreground="{StaticResource EveTextSecondary}"
                                   FontFamily="{StaticResource FontUI}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="Every alert raised this session — newest first"
                       Foreground="{StaticResource EveTextDim}"
                       FontFamily="{StaticResource FontUI}" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="34,0,34,24">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Alerts.Count, Converter={StaticResource CountToInvisibility}}">
                    <TextBlock Text="All clear" Foreground="{StaticResource EveTextSecondary}"
                               FontFamily="{StaticResource FontUI}" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tackle, cap-out, boost-lost and logi-chain alerts appear here while a fleet is monitored."
                               Foreground="{StaticResource EveTextDim}" MaxWidth="360" TextAlignment="Center" TextWrapping="Wrap"
                               FontFamily="{StaticResource FontUI}" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Alerts}" Margin="14,14,14,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FcAlert}">
                                <Border Margin="0,0,0,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource EveRaisedBg}"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource EveHairline}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="CornerRadius"    Value="8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                    <Setter Property="Background"  Value="#1c1012"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource EveCritical}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid Margin="12,10,12,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="3" RadiusX="1.5" RadiusY="1.5" Margin="0,1,10,1">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Fill" Value="{StaticResource EveAmber}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource EveCritical}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding AlertTag}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource EveAmber}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource EveCritical}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Headline}" Foreground="{StaticResource EveTextPrimary}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="13" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SubText}" Foreground="{StaticResource EveTextSecondary}"
                                                       FontFamily="{StaticResource FontUI}" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"
                                                       Visibility="{Binding SubText, Converter={StaticResource StringToVisibility}}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                                   Foreground="{StaticResource EveTextDim}" VerticalAlignment="Top"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11" Margin="10,1,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
